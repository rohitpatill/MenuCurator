# Copy to .env and fill in. If GEMINI_API_KEY is empty, the backend runs in
# MOCK_MODE (canned responses) so the UI is usable without a key.

GEMINI_API_KEY=
GEMINI_MODEL=GEMINI_MODEL=gemini-3.1-flash-lite-preview


# Optional overrides
# MOCK_MODE=false
# HOST=127.0.0.1
# PORT=5000
# FLASK_DEBUG=true
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# RESTAURANT_NAME=Vermillion
# RESTAURANT_TAGLINE=Kitchen & Bar
